@model IEnumerable<ARFurniture.AdminWeb.Models.UserViewModel>
@{
    ViewData["Title"] = "Quản lý Người dùng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-users"></i> Quản lý Người dùng</h2>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Tên đăng nhập</th>
                    <th>Họ và tên</th>
                    <th>Email</th>
                    <th>Quyền (Role)</th>
                    <th class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>#@item.Id</strong></td>
                        <td class="fw-bold">@item.Username</td>
                        <td>@item.FullName</td>
                        <td>@item.Email</td>
                        <td>
                            @if (item.Role == "Admin")
                            {
                                <span class="badge bg-danger"><i class="fas fa-user-shield"></i> Admin</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary"><i class="fas fa-user"></i> User</span>
                            }
                        </td>
                        <td class="text-end">
                            <form asp-action="ChangeRole" method="post" class="d-inline-block me-2">
                                <input type="hidden" name="id" value="@item.Id" />
                                <select name="role" class="form-select form-select-sm d-inline-block w-auto" onchange="this.form.submit()">
                                    <option value="User" selected="@(item.Role == "User")">Khách hàng (User)</option>
                                    <option value="Admin" selected="@(item.Role == "Admin")">Quản trị (Admin)</option>
                                </select>
                            </form>

                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"
                               onclick="return confirm('Hành động này sẽ XÓA VĨNH VIỄN tài khoản và giỏ hàng của người này. Bạn có chắc chắn?');">
                                <i class="fas fa-trash"></i> Xóa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>