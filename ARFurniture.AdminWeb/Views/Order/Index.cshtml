@model IEnumerable<ARFurniture.AdminWeb.Models.OrderViewModel>
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Quản lý Đơn hàng</h2>
</div>

<div class="mb-4">
    <form asp-action="Index" method="get" class="form-inline d-flex">
        <div class="input-group w-50">
            <input type="text" name="searchQuery" value="@ViewBag.SearchQuery" class="form-control" placeholder="Tìm theo tên khách hoặc SĐT...">
            <button class="btn btn-primary" type="submit">
                <i class="fas fa-search"></i> Tìm kiếm
            </button>
            @if (!string.IsNullOrEmpty(ViewBag.SearchQuery))
            {
                <a asp-action="Index" class="btn btn-secondary ms-1">Xóa</a>
            }
        </div>
    </form>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Mã ĐH</th>
                    <th>Khách hàng</th>
                    <th>Ngày đặt</th>
                    <th>Tổng tiền</th>
                    <th>Thanh toán</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>#@item.Id</strong></td>
                        <td>
                            @item.ReceiverName <br />
                            <small class="text-muted">@item.PhoneNumber</small>
                        </td>
                        <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-danger fw-bold">@item.TotalAmount.ToString("#,###") ₫</td>
                        <td>@item.PaymentMethod</td>
                        <td>
                            @if (item.OrderStatus == "Pending")
                            {
                                <span class="badge bg-warning text-dark">Chờ xác nhận</span>
                            }
                            else if (item.OrderStatus == "Shipping")
                            {
                                <span class="badge bg-primary">Đang giao hàng</span>
                            }
                            else if (item.OrderStatus == "Completed")
                            {
                                <span class="badge bg-success">Thành công</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Đã hủy</span>
                            }
                        </td>
              
                        <td>
                            <form asp-action="UpdateStatus" asp-controller="Order" method="post" class="d-flex gap-2">
                                <input type="hidden" name="id" value="@item.Id" />
                                <select name="status" class="form-select form-select-sm" style="width: 140px;">
                                    <option value="Pending" selected="@(item.OrderStatus == "Pending")">Chờ xác nhận</option>
                                    <option value="Shipping" selected="@(item.OrderStatus == "Shipping")">Giao hàng</option>
                                    <option value="Completed" selected="@(item.OrderStatus == "Completed")">Hoàn thành</option>
                                    <option value="Cancelled" selected="@(item.OrderStatus == "Cancelled")">Hủy đơn</option>
                                </select>
                                <button type="submit" class="btn btn-sm btn-outline-primary">Lưu</button>

                                <a asp-action="Details" asp-controller="Order" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">
                                    <i class="fas fa-eye"></i> Xem
                                </a>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
@if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
{
    <div class="d-flex justify-content-center mt-4">
        <nav aria-label="Page navigation">
            <ul class="pagination shadow-sm">
                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)" asp-route-searchQuery="@ViewBag.SearchQuery">
                        <i class="fas fa-chevron-left"></i> Trước
                    </a>
                </li>

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-searchQuery="@ViewBag.SearchQuery">@i</a>
                    </li>
                }

                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)" asp-route-searchQuery="@ViewBag.SearchQuery">
                        Sau <i class="fas fa-chevron-right"></i>
                    </a>
                </li>
            </ul>
        </nav>
    </div>
}