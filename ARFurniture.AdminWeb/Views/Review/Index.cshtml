@model IEnumerable<ARFurniture.AdminWeb.Models.ReviewViewModel>
@{
    ViewData["Title"] = "Quản lý Phản hồi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Quản lý Phản hồi</h2>
</div>

<div class="mb-4">
    <form asp-action="Index" method="get" class="form-inline d-flex">
        <div class="input-group w-50">
            <input type="text" name="searchQuery" value="@ViewBag.SearchQuery" class="form-control" placeholder="Tìm theo tên sản phẩm hoặc khách hàng...">
            <button class="btn btn-primary" type="submit">
                <i class="fas fa-search"></i> Tìm kiếm
            </button>
            @if (!string.IsNullOrEmpty(ViewBag.SearchQuery))
            {
                <a asp-action="Index" class="btn btn-secondary ms-1">Xóa</a>
            }
        </div>
    </form>
</div>
<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th style="width: 5%">ID</th>
                    <th style="width: 25%">Sản phẩm</th>
                    <th style="width: 15%">Khách hàng</th>
                    <th style="width: 10%">Đánh giá</th>
                    <th style="width: 25%">Bình luận</th>
                    <th style="width: 10%">Ngày gửi</th>
                    <th style="width: 10%" class="text-end">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>#@item.Id</strong></td>
                        <td class="fw-bold text-primary">@item.ProductName</td>
                        <td>@item.FullName</td>
                        <td>
                            <span class="text-warning fw-bold">@item.Rating <i class="fas fa-star"></i></span>
                        </td>
                        <td>
                            <div style="max-height: 60px; overflow-y: auto; font-style: italic; color: #555;">
                                "@item.Comment"
                            </div>
                        </td>
                        <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="text-end">
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"
                               onclick="return confirm('Bạn có chắc chắn muốn xóa vĩnh viễn đánh giá này? Điểm sao của sản phẩm sẽ được tự động tính lại.');">
                                <i class="fas fa-trash"></i> Xóa
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
        {
            <div class="d-flex justify-content-center mt-4">
                <nav aria-label="Page navigation">
                    <ul class="pagination shadow-sm">
                        <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)" asp-route-searchQuery="@ViewBag.SearchQuery">
                                <i class="fas fa-chevron-left"></i> Trước
                            </a>
                        </li>

                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-searchQuery="@ViewBag.SearchQuery">@i</a>
                            </li>
                        }

                        <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)" asp-route-searchQuery="@ViewBag.SearchQuery">
                                Sau <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>