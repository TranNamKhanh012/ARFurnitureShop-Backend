@model ARFurniture.AdminWeb.Models.DashboardViewModel
@using System.Text.Json

@{
    ViewData["Title"] = "Dashboard Admin";

    // Convert dữ liệu C# sang chuỗi JSON để Javascript đọc được
    var chartLabels = JsonSerializer.Serialize(Model.WeeklyRevenue?.Select(x => x.Date));
    var chartData = JsonSerializer.Serialize(Model.WeeklyRevenue?.Select(x => x.Revenue));
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Tổng Quan Hệ Thống</h1>

    <a href="@Url.Action("ExportReport", "Home")" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
        <i class="fas fa-download fa-sm text-white-50"></i> Xuất Báo Cáo
    </a>
</div>

    <div class="row">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Doanh Thu Hôm Nay</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TodayRevenue.ToString("N0") đ</div>
                        </div>
                        <div class="col-auto"><i class="fas fa-calendar-day fa-2x text-gray-300"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Doanh Thu (7 Ngày)</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.WeeklyRevenueTotal.ToString("N0") đ</div>
                        </div>
                        <div class="col-auto"><i class="fas fa-calendar-week fa-2x text-gray-300"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Doanh Thu Tháng @DateTime.Now.Month</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.MonthlyRevenue.ToString("N0") đ</div>
                        </div>
                        <div class="col-auto"><i class="fas fa-calendar-alt fa-2x text-gray-300"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Tổng Khách Hàng</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalUsers</div>
                        </div>
                        <div class="col-auto"><i class="fas fa-users fa-2x text-gray-300"></i></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-dark shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-dark text-uppercase mb-1">Danh Mục Sản Phẩm</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalCategories</div>
                        </div>
                        <div class="col-auto"><i class="fas fa-tags fa-2x text-gray-300"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Sản Phẩm Đã Bán</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalProductsSold</div>
                        </div>
                        <div class="col-auto"><i class="fas fa-shopping-bag fa-2x text-gray-300"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-secondary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-secondary text-uppercase mb-1">Tổng Hàng Trong Kho</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalStock</div>
                        </div>
                        <div class="col-auto"><i class="fas fa-boxes fa-2x text-gray-300"></i></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-danger shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Thuế</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.MonthlyTax.ToString("N0") đ</div>
                        </div>
                        <div class="col-auto"><i class="fas fa-file-invoice-dollar fa-2x text-gray-300"></i></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-xl-8 col-lg-7">
            <div class="card shadow mb-4">
                <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                    <h6 class="m-0 font-weight-bold text-primary">Biểu Đồ Doanh Thu (7 Ngày Gần Nhất)</h6>
                </div>
                <div class="card-body">
                    <div class="chart-area" style="height: 320px;">
                        <canvas id="myRevenueChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-4 col-lg-5">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Giao Dịch Gần Đây</h6>
                </div>
                <div class="card-body" style="height: 320px; overflow-y: auto;">
                    <ul class="list-group list-group-flush">
                        @if (Model.RecentOrders != null && Model.RecentOrders.Count > 0)
                        {
                            foreach (var order in Model.RecentOrders)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                    <div>
                                        <h6 class="my-0 font-weight-bold text-dark">#@order.Id - @order.ReceiverName</h6>
                                        <small class="text-muted">@order.OrderDate.ToString("dd/MM/yy HH:mm")</small>
                                    </div>
                                    <span class="text-success font-weight-bold">@order.TotalAmount.ToString("N0")đ</span>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="list-group-item text-center text-muted">Chưa có giao dịch nào</li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Nhận dữ liệu JSON từ C# bắn xuống
        const labels = @Html.Raw(chartLabels ?? "[]");
        const dataValues = @Html.Raw(chartData ?? "[]");

        const ctx = document.getElementById('myRevenueChart').getContext('2d');

        // Cấu hình biểu đồ Line
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Doanh thu (VNĐ)',
                    data: dataValues,
                    backgroundColor: 'rgba(78, 115, 223, 0.1)', // Màu nền dưới dải băng
                    borderColor: 'rgba(78, 115, 223, 1)',       // Màu đường vẽ
                    pointRadius: 4,
                    pointBackgroundColor: 'rgba(78, 115, 223, 1)',
                    pointBorderColor: '#fff',
                    pointHoverRadius: 6,
                    fill: true,
                    tension: 0.3 // Làm cong đường vẽ cho mượt
                }]
            },
            options: {
                maintainAspectRatio: false,
                responsive: true,
                plugins: {
                    legend: { display: false } // Giấu cái chú thích thừa đi
                },
                scales: {
                    x: {
                        grid: { display: false } // Giấu lưới dọc
                    },
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                // Format số tiền trên trục Y (Thêm dấu phẩy)
                                return value.toLocaleString('vi-VN') + ' đ';
                            }
                        }
                    }
                }
            }
        });
    });
</script>