<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        body {
            background-color: #f4f7f6;
            overflow-x: hidden;
            margin: 0;
        }
        /* Cấu hình Sidebar màu đen bên trái */
        #sidebar {
            width: 260px;
            height: 100vh;
            background-color: #344253;
            position: fixed;
            color: #fff;
            top: 0;
            left: 0;
        }

            #sidebar .logo {
                padding: 20px;
                font-size: 22px;
                font-weight: bold;
                text-align: center;
                border-bottom: 1px solid #455567;
            }

            #sidebar ul {
                list-style: none;
                padding: 0;
                margin-top: 20px;
            }

                #sidebar ul li a {
                    display: block;
                    padding: 15px 20px;
                    color: #a1b1c2;
                    text-decoration: none;
                    font-size: 15px;
                    transition: 0.3s;
                }

                    #sidebar ul li a:hover, #sidebar ul li a.active {
                        color: #fff;
                        background-color: #2c3845;
                    }

                    #sidebar ul li a i {
                        width: 30px;
                    }

        /* Phần ruột bên phải */
        #content {
            margin-left: 260px;
            padding: 30px;
            width: calc(100% - 260px);
            min-height: 100vh;
        }
    </style>
</head>
<body>

    @{
        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
    }

    <div class="d-flex">
        <div id="sidebar">
            <div class="logo">Fashion Admin</div>
            <ul>
                <li>
                    <a asp-controller="Home" asp-action="Index" class="@(currentController == "Home" ? "active" : "")">
                        <i class="fas fa-tachometer-alt"></i> Dashboard
                    </a>
                </li>

                <li>
                    <a asp-controller="Product" asp-action="Index" class="@(currentController == "Product" ? "active" : "")">
                        <i class="fas fa-fw fa-box"></i> <span>Quản lý Sản phẩm</span>
                    </a>
                </li>

                <li>
                    <a asp-controller="Category" asp-action="Index" class="@(currentController == "Category" ? "active" : "")">
                        <i class="fas fa-tags"></i> Quản lý Danh mục
                    </a>
                </li>
                <li>
                    <a asp-controller="User" asp-action="Index" class="@(currentController == "User" ? "active" : "")">
                        <i class="fas fa-users"></i> Quản lý Người dùng
                    </a>
                </li>
                <li>
                    <a asp-controller="Order" asp-action="Index" class="@(currentController == "Order" ? "active" : "")">
                        <i class="fas fa-file-invoice-dollar"></i> Quản lý Đơn hàng
                    </a>
                </li>
                <li><a href="#"><i class="fas fa-newspaper"></i> Quản lý Bài viết</a></li>
                <li><a href="#"><i class="fas fa-comments"></i> Quản lý Phản hồi</a></li>
                <li><a href="#"><i class="fas fa-sign-out-alt"></i> Về trang chủ</a></li>
            </ul>
        </div>

        <div id="content">
            @RenderBody()
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>