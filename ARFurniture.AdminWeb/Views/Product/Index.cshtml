@model IEnumerable<ARFurniture.AdminWeb.Models.AdminProductViewModel>
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    // Lấy link "http://localhost:5103/api/" và cắt chữ "api/" đi để thành "http://localhost:5103/"
    string apiUrl = Configuration.GetSection("ApiSettings:BaseUrl").Value.Replace("api/", "");
}

@{
    ViewData["Title"] = "Quản lý Sản phẩm";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Quản lý Sản phẩm</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus"></i> Thêm sản phẩm mới</a>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger mb-4">@ViewBag.Error</div>
}

<div class="mb-4">
    <form asp-action="Index" method="get" class="form-inline d-flex">
        <div class="input-group w-50">
            <input type="text" name="searchQuery" value="@ViewBag.SearchQuery" class="form-control" placeholder="Tìm theo tên sản phẩm...">
            <button class="btn btn-primary" type="submit">
                <i class="fas fa-search"></i> Tìm kiếm
            </button>
            @if (!string.IsNullOrEmpty(ViewBag.SearchQuery))
            {
                <a asp-action="Index" class="btn btn-secondary ms-1" title="Xóa tìm kiếm">Xóa</a>
            }
        </div>
    </form>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 5%;">ID</th>
                        <th class="text-center" style="width: 10%;">Ảnh</th>
                        <th>Tên sản phẩm</th>
                        <th class="text-end" style="width: 12%;">Giá bán</th>
                        <th class="text-end" style="width: 12%;">Giá gốc</th>
                        <th class="text-center" style="width: 15%;">Hàng trong kho</th>
                        <th class="text-center" style="width: 10%;">Đã bán</th>
                        <th class="text-end" style="width: 15%;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>#@item.Id</strong></td>
                                <td class="text-center">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@(apiUrl)images/@item.ImageUrl" alt="@item.Name" style="width: 60px; height: 60px; object-fit: cover; border-radius: 4px;" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">Chưa có ảnh</span>
                                    }
                                </td>
                                <td class="fw-bold text-secondary">@item.Name</td>
                                <td class="text-end text-danger fw-bold">@item.SellingPrice.ToString("N0")đ</td>
                                <td class="text-end text-muted">@item.OriginalPrice.ToString("N0")đ</td>
                                <td class="text-center">@item.StockQuantity</td>
                                <td class="text-center">@item.SoldQuantity</td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                        <i class="fas fa-edit"></i> Sửa
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger ms-1"
                                       onclick="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này không? Dữ liệu không thể khôi phục!');">
                                        <i class="fas fa-trash"></i> Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted">Không có dữ liệu sản phẩm nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (ViewBag.TotalPages != null && ViewBag.TotalPages > 1)
        {
            <div class="d-flex justify-content-center mt-4">
                <nav aria-label="Page navigation">
                    <ul class="pagination shadow-sm">
                        <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)" asp-route-searchQuery="@ViewBag.SearchQuery">
                                <i class="fas fa-chevron-left"></i> Trước
                            </a>
                        </li>

                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-searchQuery="@ViewBag.SearchQuery">@i</a>
                            </li>
                        }

                        <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)" asp-route-searchQuery="@ViewBag.SearchQuery">
                                Sau <i class="fas fa-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>